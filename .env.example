# WeChat Official Account credentials for tools/wechat.py
#
# Usage: copy this file to ".env" in the same directory and fill in real values.
#   cp .env.example .env      (Linux/macOS)
#   Copy-Item .env.example .env   (PowerShell)
#
# ".env" is gitignored — your real AppSecret never gets committed.
# Real shell environment variables, if set, take precedence over this file.

WECHAT_APP_ID=
WECHAT_APP_SECRET=
